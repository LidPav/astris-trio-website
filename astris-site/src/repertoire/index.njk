---
layout: layout.njk
title: Programme
description: Konzertprogramme des Astris Trio (Klassik bis Moderne)
---

<section class="editorial">
  <div class="editorial__header">
    <h1 class="editorial__title">Repertoire</h1>
    <p class="editorial__lead">
      Das Repertoire des Astris Trios umfasst Werke verschiedenster Epochen – von der Klassik
      bis hin zur zeitgenössischen Musik – und spiegelt die stilistische Vielfalt und Offenheit
      des Ensembles wider.
    </p>
  </div>

  <div class="editorial__grid">
    <div class="editorial__main">

      <h2>Repertoire &amp; Programme</h2>

      {# Reihenfolge der Epochen bewusst festgelegt #}
      {% set epochOrder = ['Klassik', 'Romantik', 'Moderne', 'Zeitgenössisch'] %}

<section id="programme" class="programme">
  {% for p in programmes %}
    <article class="programme__item" id="{{ p.id }}">
      
      <h3 class="programme__title">{{ p.title }}</h3>

      {# Only render works if they exist and are not empty #}
      {% if p.works and p.works.length %}
        <ul class="programme__works">
          {% for w in p.works %}
            <li>{{ w }}</li>
          {% endfor %}
        </ul>
      {% endif %}

      {% if p.blurb %}
        <p class="programme__blurb">
          {{ p.blurb }}
        </p>
      {% endif %}

      {# Only render meta info if duration or idealFor exist #}
      {% if p.duration or p.idealFor %}
        <p class="programme__meta muted">
          {% if p.duration %}
            <strong>Dauer:</strong> {{ p.duration }}
          {% endif %}
          {% if p.idealFor %}
            <br>{{ p.idealFor }}
          {% endif %}
        </p>
      {% endif %}

    </article>
  {% endfor %}
</section>

    </div>

    <aside class="editorial__aside">
      <div class="aside-card">
        <h3>Programme</h3>
        <p class="muted">
          <div class="aside-card">
  <h3>Programme</h3>
  <ul class="muted">
    {% for p in programmes %}
      <li><a href="#{{ p.id }}">{{ p.title }}</a></li>
    {% endfor %}
  </ul>
</div>
        </p>
      </div>

      <div class="aside-card">
        <h3>Besetzungen</h3>
        <p class="muted">
          Klavier · Violine · Violoncello<br>
          (auf Anfrage auch mit Gästen)
        </p>
      </div>
    </aside>
  </div>
</section>
